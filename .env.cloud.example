# ── Biến môi trường tầng CLOUD (chạy trên AWS EC2) ──────────────────────────
# Copy: cp .env.cloud.example .env.cloud
# Chạy: docker compose -f docker-compose.cloud.yml --env-file .env.cloud up -d

# ── MySQL tầng Cloud ─────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=Uet123
MYSQL_DATABASE=iotdata_fog
MYSQL_USER=user1
MYSQL_PASSWORD=Uet123

# ── Storm / Topology ─────────────────────────────────────────────────────────
# Phải khớp với FLUSH_INTERVAL_SEC bên gateway để cửa sổ tổng hợp đúng.
FLUSH_INTERVAL_SEC=60

# ── Cảnh báo Slack đã chuyển sang tầng GATEWAY ───────────────────────────────
# Đặt SLACK_WEBHOOK_URL trong .env.gateway (Slack bắn từ biên). Xem RUNBOOK_ALERTS.md.

# ── Ngưỡng cảnh báo cho dashboard Cloud (Bolt_cloudMerge → notification panel) ─
# Không phải Slack — chỉ là feed notification hiển thị trên web dashboard.
# Watt tối đa 1 thiết bị trước khi cảnh báo (mặc định 2000W)
ALERT_DEVICE_MAX_W=2000
# Watt tối đa toàn bộ 1 ngôi nhà (mặc định 20000W)
ALERT_HOUSE_MAX_W=20000
# Cooldown cảnh báo cùng key (giây). Mặc định 60 giây.
ALERT_COOLDOWN_SEC=60
# Window size (phút) dùng để check ngưỡng. 5 = dùng cửa sổ 5 phút.
ALERT_WINDOW_MIN=5
