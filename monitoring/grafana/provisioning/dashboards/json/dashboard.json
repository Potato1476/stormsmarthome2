{
  "title": "Storm Performance Benchmark",
  "uid": "storm-benchmark",
  "schemaVersion": 39,
  "refresh": "5s",
  "panels": [
    {
      "type": "row",
      "title": "1. Topology End-to-End Metrics (Latency & Throughput)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100
    },
    {
      "id": 1,
      "title": "Topology Complete Latency",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "expr": "topology_stats_complete_latency",
          "legendFormat": "{{topology}} - Complete Latency",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 2,
      "title": "Topology Messages Acked (Throughput)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "rate(topology_stats_acked[1m])",
          "legendFormat": "{{topology}} - Acked/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "type": "row",
      "title": "2. Bolt Processing Performance",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 200
    },
    {
      "id": 3,
      "title": "Bolt Process Latency",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "targets": [
        {
          "expr": "bolts_process_latency",
          "legendFormat": "{{bolt_id}} - Process Latency",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 4,
      "title": "Bolt Execute Latency",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "expr": "bolts_execute_latency",
          "legendFormat": "{{bolt_id}} - Execute Latency",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 5,
      "title": "Bolt Capacity (Load)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "targets": [
        {
          "expr": "bolts_capacity",
          "legendFormat": "{{bolt_id}} - Capacity",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        }
      }
    },
    {
      "id": 6,
      "title": "Spouts Emitted Rate",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "targets": [
        {
          "expr": "rate(spouts_emitted[1m])",
          "legendFormat": "{{spout_id}} - Emitted/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "type": "row",
      "title": "3. Cluster Resources Distribution (Split vs Monolithic)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "id": 300
    },
    {
      "id": 7,
      "title": "Worker Cluster Used",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "targets": [
        {
          "expr": "worker_cluster_used",
          "legendFormat": "{{ClusterHost}} - Used",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 8,
      "title": "Worker Cluster Total",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "targets": [
        {
          "expr": "worker_cluster_total",
          "legendFormat": "{{ClusterHost}} - Total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    }
  ]
}