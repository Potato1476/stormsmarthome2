# ── Biến môi trường tầng GATEWAY (giả lập Pi trên máy local) ─────────────────
# Copy: cp .env.gateway.example .env.gateway
# Chạy: docker compose -f docker-compose.gateway.yml --env-file .env.gateway up -d
#
# Luồng dữ liệu:
#   Publisher → localhost:1883 (local-mqtt, raw data ở local)
#               → 8 Gateway Storm tổng hợp cục bộ
#                   → <CLOUD_PUBLIC_IP>:1883 (chỉ aggregated results)

# ── IP public của EC2 Cloud (BẮT BUỘC) ───────────────────────────────────────
# Lấy bằng: cd infrastructure/terraform && terraform output -raw cloud_public_ip
CLOUD_PUBLIC_IP=

# Cổng MQTT của Cloud broker (mặc định 1883 — khớp docker-compose.cloud.yml)
CLOUD_MQTT_PORT=1883

# ── Cửa sổ tổng hợp & nhịp đẩy ───────────────────────────────────────────────
# FLUSH_INTERVAL_SEC phải khớp với bên Cloud.
FLUSH_INTERVAL_SEC=60
GATEWAY_WINDOWS=1,5,10,15,30

# ── Ràng buộc JVM khớp Raspberry Pi 3 (1 GB RAM) ────────────────────────────
# Không cần -Dstorm.conf.file ở đây — đã hardcode trong ENTRYPOINT của Dockerfile.
JAVA_OPTS=-Xmx384m -XX:+UseSerialGC -Djava.awt.headless=true

# ── Cảnh báo đa kênh (Slack) + phát hiện bất thường tại Gateway ─────────────
# Dán Slack Incoming Webhook URL vào đây để BẬT cảnh báo. Để trống = TẮT.
#   Tạo webhook: Slack → Apps → Incoming Webhooks → Add to Slack → chọn kênh.
SLACK_WEBHOOK_URL=
ALERT_ENABLED=true
# Trần công suất tuyệt đối (W): vượt ngưỡng này → CRITICAL ngay (không cần học).
# Dữ liệu giả lập (publish_csv.sh --synthetic) sinh 0..3000W → 2500 sẽ bắn cảnh báo.
ALERT_HARD_CEILING_W=2500
# Ngưỡng z-score (số sigma lệch khỏi baseline học bằng EWMA) → WARNING.
ALERT_Z_THRESHOLD=3.0
# Hệ số làm mượt EWMA (0..1): cao = phản ứng nhanh, thấp = baseline ổn định hơn.
ALERT_EWMA_ALPHA=0.3
# Số mẫu cần quan sát trước khi bật phát hiện theo z-score (trần luôn hoạt động).
ALERT_WARMUP=20
# Khoảng cách tối thiểu giữa 2 cảnh báo CHO CÙNG 1 thiết bị (giây) — chống spam.
ALERT_COOLDOWN_SEC=60
# Khoảng cách tối thiểu giữa 2 lần POST lên Slack (ms) — bảo vệ rate limit.
ALERT_MIN_INTERVAL_MS=1000
