# IP public cua may GATEWAY (may chay gateway/docker-compose.yaml)
GATEWAY_PUBLIC_IP=1.2.3.4

# Danh sach bolt duoc gan tag "cloud" khi nop topology (topo-submit).
# Mac dinh giong code goc: sum,forecast -> chay o cloud; split,avg -> gateway.
# Co the tinh chinh theo tung window, vi du: sum,forecast,avg-60,avg-120
CLOUD_BOLTS=sum,forecast
